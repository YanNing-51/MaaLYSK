{
	"task": [
		{
			"name": "🎁使用兑换码",
			"entry": "进入兑换码兑换",
			"default_check": false,
			"controller": ["ADB模拟器"],
			"description": "不支持PlayCover,Playcover仅能手动输入兑换码",
			"option": ["输入当前兑换码"]
		},
		{
			"name": "✉️邮箱领取",
			"entry": "进入邮箱领取",
			"default_check": false
		},
		{
			"name": "📖自动读剧情",
			"entry": "进入自动过剧情",
			"default_check": false,
			"option": ["剧情选择"],
			"description": "1、主线剧情上限16章，遇到战斗章节可能卡住，请手动过完战斗章节再开始<br>2、过剧情、主线入口等因字体和UI变化原因，可能会有识别问题，偶尔遇到自己过剧情后再开始任务，无法使用自己过任务。<br>3、过主线剧情虽已配备自动导航，但为防止意外问题，请在要读的主线剧情页（左下角有世界深处）启动，并保证当前页面有要开始的剧情章节数字。",
			"pipeline_override": {
				"点成2倍速": {
					"next": [
						"主线页面确认",
						"[JumpBack]选剧情选项",
						"[JumpBack]跳过吹气",
						"[JumpBack]剧情圈圈选项点一点",
						"[JumpBack]自动过剧情点点",
						"[JumpBack]live剧情等待",
						"[JumpBack]退出战斗追击页面",
						"[JumpBack]加载页面等待_竖屏",
						"[JumpBack]加载页面等待_横屏"
					]
				},
				"退出战斗_胜利": {
					"timeout": 25000,
					"next": [
						"主线页面确认",
						"[JumpBack]点击主线",
						"[JumpBack]加载页面等待_横屏",
						"[JumpBack]加载页面等待_竖屏",
						"[JumpBack]返回上一级页面"
					]
				},
				"退出点击popop": {
					"enabled": false
				}
			}
		}
	],
